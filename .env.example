# ============================================================
# AUTH MODE
# "auth0" = uses Auth0 Token Vault (REQUIRED for hackathon judging)
# "local" = local JWT + encrypted SQLite vault (dev/demo, no Auth0 needed)
# ============================================================
AUTH_MODE=auth0

# ============================================================
# Auth0 — FREE dev tenant at auth0.com/signup
# Token Vault is available on the free tier
# ============================================================
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-spa-client-id
AUTH0_CLIENT_SECRET=your-m2m-client-secret
AUTH0_AUDIENCE=vanguard-api

# ============================================================
# OAuth App credentials (for connecting Slack/GitHub via Token Vault)
# Create free OAuth apps at:
#   Slack:  api.slack.com/apps
#   GitHub: github.com/settings/developers
# ============================================================
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================
# Local vault fallback (used when AUTH_MODE=local)
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ============================================================
VAULT_ENCRYPTION_KEY=

# App secret (generate: openssl rand -hex 32)
SECRET_KEY=change-me

# Ollama (runs locally via Docker — free)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=mistral

# Frontend
NEXT_PUBLIC_AUTH_MODE=auth0
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-spa-client-id
NEXT_PUBLIC_AUTH0_AUDIENCE=vanguard-api
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
